# Environment Variables — Saddles Market Backend
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL on Railway) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname
# Or individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saddles_market
DB_USER=postgres
DB_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_64_chars_please_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_minimum_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=support@saddlesmarket.com
FROM_NAME=Saddles Market
# Admin order notification inbox — set to any real email you can check.
# Defaults to sales@saddlesmarket.com if not set.
ADMIN_EMAIL=sales@saddlesmarket.com

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://saddlesmarket.com
ADMIN_PASSWORD=Boyalinco$10

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
